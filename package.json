{
  "private": true,
  "sideEffects": false,
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "type-check": "tsc --project tsconfig.json",
    "prepare": "husky",
    "generate-token": "chmod +x ./token-generator.sh && ./token-generator.sh",
    "generate-openapi-types": "npx openapi-typescript",
    "generate-mock-data": "npx tsx scripts/generer-mock-data.ts",
    "oppdater-mock-data": "npx tsx scripts/oppdater-mock-data.ts",
    "graphql-codegen": "graphql-codegen --config codegen.ts",
    "test": "vitest run",
    "lint": "eslint"
  },
  "prettier": {
    "printWidth": 100,
    "tailwindStylesheet": "./app/global-darkside.css",
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --list-different",
      "eslint --no-warn-ignored --max-warnings 0",
      "bash -c 'npm run type-check'"
    ]
  },
  "dependencies": {
    "@elastic/ecs-pino-format": "1.5.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
