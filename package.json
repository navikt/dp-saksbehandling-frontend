    "@navikt/ds-react": "8.10.4",
    "@navikt/ds-tailwind": "8.10.4",
    "@navikt/ds-tokens": "8.6.0",
    "@navikt/oasis": "4.1.4",
    "@opentelemetry/auto-instrumentations-node": "0.71.0",
    "@opentelemetry/sdk-node": "0.213.0",
    "@opentelemetry/sdk-trace-node": "2.6.0",
    "@portabletext/block-tools": "5.1.1",
    "@portabletext/editor": "6.6.2",
    "@portabletext/keyboard-shortcuts": "2.1.2",
    "@portabletext/react": "6.0.3",
    "@portabletext/to-html": "5.0.2",
    "@portabletext/toolbar": "7.0.27",
    "@react-router/node": "7.13.1",
    "@react-router/serve": "7.13.1",
